# ==============================================================================
# GraphVerify environment configuration
#
# Copy this file to `.env` in the same directory and fill in real values.
# `.env` is loaded automatically at import time by graphverify.config
# (via python-dotenv) and is git-ignored — never commit real keys.
#
#   cp .env.example .env
# ==============================================================================

# ------------------------------------------------------------------------------
# OpenAI-compatible LLM backend
# Required for: claim decomposition, triple extraction, evidence-graph triple
# extraction, the GraphVerify-Hybrid verdict head, RAG answer generation, and
# every text-based baseline (SAFE, RARR, FIRE, CiteFix, Hybrid KG-LLM,
# LLM-text-only verifier) when --llm_backend openai is used.
# Get a key at https://platform.openai.com/api-keys
# ------------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: point at any OpenAI-compatible endpoint instead of api.openai.com,
# e.g. a local vLLM/Ollama/text-generation-inference server serving
# Qwen2.5-7B-Instruct. Leave unset to use the default OpenAI endpoint.
# Example: OPENAI_BASE_URL=http://localhost:8000/v1
OPENAI_BASE_URL=

# ------------------------------------------------------------------------------
# HuggingFace Hub token
# Required only if a dataset or model you request is gated/private. Public
# datasets used by this repo (HotpotQA, 2WikiMultiHopQA, MuSiQue, FEVER,
# BAAI/bge-base-en-v1.5) do not require a token, but setting HF_TOKEN avoids
# anonymous rate limits during graph_build.py / dataset/loader.py downloads.
# Get a token at https://huggingface.co/settings/tokens
# ------------------------------------------------------------------------------
HF_TOKEN=

# ------------------------------------------------------------------------------
# Anthropic API key
# Optional. Only needed if you run a baseline or generator with
# --llm_backend anthropic (see graphverify/llm_client.py) to use a Claude
# model as the RAG answer generator or as an LLM-judge baseline variant.
# Get a key at https://console.anthropic.com/settings/keys
# ------------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ------------------------------------------------------------------------------
# Integration test gate
# Set to 1 to allow tests/integration/* to run. These tests make real network
# calls (OpenAI API billing, HuggingFace model downloads) and are skipped by
# default. See docs/HARDWARE_SOFTWARE_REQUIREMENTS.md for expected cost.
# ------------------------------------------------------------------------------
RUN_INTEGRATION_TESTS=0
